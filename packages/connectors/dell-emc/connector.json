  "discovery": {
    "schedule": {
      "interval": 3600,
      "unit": "seconds"
    },
    "retry_policy": {
      "max_attempts": 3,
      "backoff_strategy": "exponential",
      "initial_delay": 2000,
      "max_delay": 30000
    },
    "rate_limiting": {
      "requests_per_minute": 60,
      "concurrent_requests": 5
    }
  },
  "health_check": {
    "endpoint": "/api/types/system/instances",
    "method": "GET",
    "interval": 300,
    "timeout": 10000,
    "expected_status": 200
  },
  "documentation": {
    "overview": "The Dell EMC Storage connector discovers storage arrays, pools, volumes, and connected hosts from Dell EMC Unity, PowerStore, and PowerMax storage systems. It uses the Dell EMC REST API to retrieve configuration and health information.",
    "setup_instructions": [
      "1. Ensure you have a Dell EMC storage array with REST API access enabled",
      "2. Create a read-only service account with appropriate permissions",
      "3. Obtain the management URL for your storage array",
      "4. Configure the connector with your credentials and array type",
      "5. Test the connection using the health check endpoint",
      "6. Run initial discovery to populate your CMDB"
    ],
    "required_permissions": [
      "Read access to system information",
      "Read access to storage pool configuration",
      "Read access to volume (LUN) configuration",
      "Read access to host configuration",
      "API access enabled on the storage array"
    ],
    "supported_versions": [
      "Dell EMC Unity: 4.x, 5.x",
      "Dell EMC PowerStore: 1.x, 2.x, 3.x",
      "Dell EMC PowerMax: 9.x, 10.x"
    ],
    "api_reference": "https://developer.dell.com/apis",
    "troubleshooting": {
      "connection_failed": "Verify management URL is correct and storage array is reachable. Check firewall rules allow HTTPS traffic.",
      "authentication_failed": "Verify username and password are correct. Ensure account has API access enabled.",
      "timeout_errors": "Increase timeout value in configuration. Check network latency to storage array.",
      "ssl_errors": "If using self-signed certificates, set verify_ssl to false in configuration.",
      "empty_results": "Verify account has read permissions for all resource types. Check array_type is correct."
    }
  },
