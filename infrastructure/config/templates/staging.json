{
  "env": "staging",
  "server": {
    "port": 3000,
    "host": "0.0.0.0",
    "trustProxy": true
  },
  "databases": {
    "neo4j": {
      "database": "neo4j",
      "maxConnectionPoolSize": 30,
      "connectionTimeout": 30000
    },
    "postgres": {
      "port": 5432,
      "maxConnections": 15,
      "ssl": {
        "enabled": true,
        "rejectUnauthorized": true
      }
    },
    "redis": {
      "port": 6379,
      "db": 0,
      "maxRetriesPerRequest": 3,
      "enableReadyCheck": true,
      "tls": {
        "enabled": false
      }
    },
    "kafka": {
      "clientId": "cmdb-staging",
      "groupId": "cmdb-staging-consumers",
      "ssl": false
    }
  },
  "cloudProviders": {
    "aws": {
      "enabled": true,
      "region": "us-east-1"
    },
    "azure": {
      "enabled": false
    },
    "gcp": {
      "enabled": false
    }
  },
  "auth": {
    "jwt": {
      "accessTokenExpiresIn": "30m",
      "refreshTokenExpiresIn": "7d",
      "issuer": "happycmdb",
      "audience": "cmdb-api"
    },
    "bcrypt": {
      "rounds": 12
    },
    "apiKeys": {
      "enabled": true,
      "headerName": "X-API-Key"
    }
  },
  "rateLimit": {
    "enabled": true,
    "windowMs": 60000,
    "endpoints": {
      "discovery": {
        "max": 10,
        "windowMs": 60000
      },
      "query": {
        "max": 100,
        "windowMs": 60000
      },
      "graphql": {
        "max": 50,
        "windowMs": 60000
      },
      "admin": {
        "max": 30,
        "windowMs": 60000
      },
      "auth": {
        "max": 5,
        "windowMs": 300000
      }
    }
  },
  "cors": {
    "enabled": true,
    "credentials": true,
    "maxAge": 86400
  },
  "ssl": {
    "enabled": true,
    "redirectHttp": true
  },
  "secrets": {
    "provider": "aws-secrets-manager",
    "awsSecretsManager": {
      "region": "us-east-1",
      "secretName": "cmdb/staging"
    },
    "cacheTtl": 300
  },
  "logging": {
    "level": "info",
    "format": "json",
    "colorize": false,
    "auditEnabled": true,
    "auditLevel": "info"
  },
  "security": {
    "helmet": {
      "enabled": true,
      "contentSecurityPolicy": {
        "enabled": true,
        "directives": {
          "defaultSrc": ["'self'"],
          "styleSrc": ["'self'", "'unsafe-inline'"],
          "scriptSrc": ["'self'"],
          "imgSrc": ["'self'", "data:", "https:"],
          "connectSrc": ["'self'"],
          "fontSrc": ["'self'"],
          "objectSrc": ["'none'"],
          "mediaSrc": ["'self'"],
          "frameSrc": ["'none'"]
        }
      },
      "hsts": {
        "enabled": true,
        "maxAge": 31536000,
        "includeSubDomains": true,
        "preload": false
      }
    },
    "csrf": {
      "enabled": false,
      "ignoredRoutes": ["/api/auth/login", "/graphql"]
    }
  },
  "validation": {
    "stripUnknown": true,
    "abortEarly": false,
    "sanitizeInput": true
  },
  "discovery": {
    "enabled": true,
    "interval": 3600000,
    "batchSize": 100,
    "maxRetries": 3,
    "retryDelay": 2000
  },
  "monitoring": {
    "enabled": true,
    "metricsPort": 9090,
    "healthCheckPath": "/health"
  }
}
