{
  "id": "zendesk",
  "type": "zendesk",
  "category": "connector",
  "connector_category": "itsm",
  "data_types": ["itil"],
  "name": "Zendesk",
  "version": "1.0.0",
  "description": "Integration with Zendesk for IT support tickets and incidents (read-only for dashboard reference)",
  "author": "HappyCMDB",
  "verified": true,
  "icon": "zendesk",
  "provider": "zendesk",
  "protocol": "api_token",
  "logo_url": "https://d1eipm3vz40hy0.cloudfront.net/images/logos/zendesk-logo.svg",
  "documentation_url": "https://developer.zendesk.com/api-reference/",
  "capabilities": {
    "extraction": true,
    "relationships": false,
    "incremental": true,
    "bidirectional": false
  },
  "configuration_schema": {
    "type": "object",
    "required": ["subdomain", "email", "api_token"],
    "properties": {
      "subdomain": {
        "type": "string",
        "description": "Zendesk subdomain (e.g., yourcompany from yourcompany.zendesk.com)"
      },
      "email": {
        "type": "string",
        "description": "Zendesk admin email address"
      },
      "api_token": {
        "type": "string",
        "description": "Zendesk API token (Admin Center → Apps and integrations → APIs → Zendesk API)",
        "format": "password"
      }
    }
  },
  "resources": [
    {
      "id": "incidents",
      "name": "Incidents",
      "description": "IT incident tickets from Zendesk (type: incident)",
      "type": "incident",
      "data_type": "itil",
      "target_storage": "postgresql:fact_incidents",
      "enabled_by_default": false,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "tag_filter": {
            "type": "string",
            "description": "Filter tickets by tag (e.g., incident, it_support)",
            "default": "incident"
          },
          "sync_closed": {
            "type": "boolean",
            "default": false,
            "description": "Sync closed/solved tickets"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 100,
        "rate_limit": 10
      },
      "field_mappings": {
        "number": "id",
        "short_description": "subject",
        "description": "description",
        "priority": "priority",
        "severity": "type",
        "state": "status",
        "impact": "custom_fields.impact",
        "urgency": "custom_fields.urgency",
        "category": "custom_fields.category",
        "subcategory": "custom_fields.subcategory",
        "assigned_to": "assignee.name",
        "assignment_group": "group.name",
        "caller": "requester.name",
        "affected_ci": "custom_fields.affected_ci",
        "business_service": "custom_fields.business_service",
        "opened_at": "created_at",
        "resolved_at": "updated_at",
        "closed_at": "updated_at",
        "close_code": "satisfaction_rating.comment",
        "resolution": "custom_fields.resolution",
        "sla_due": "slas.policy_metrics[0].breach_at",
        "created": "created_at",
        "updated": "updated_at"
      }
    }
  ],
  "authentication": {
    "required": true,
    "methods": ["api_token"],
    "fields": [
      {
        "name": "email",
        "label": "Email",
        "type": "string",
        "required": true,
        "sensitive": false
      },
      {
        "name": "api_token",
        "label": "API Token",
        "type": "string",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "rate_limits": {
    "requests_per_second": 10,
    "requests_per_minute": 200,
    "requests_per_hour": 700
  },
  "supported_operations": [
    "sync_incidents"
  ],
  "default_schedule": "0 */4 * * *",
  "tags": [
    "itsm",
    "zendesk",
    "support",
    "ticketing",
    "incident-management",
    "service-desk",
    "help-desk"
  ]
}
