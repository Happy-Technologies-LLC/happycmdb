{
  "dashboard": {
    "title": "CMDB Overview Dashboard",
    "tags": ["cmdb", "overview", "inventory"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5m",
    "time": {
      "from": "now-30d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Total CIs by Type",
        "type": "piechart",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT ci_type AS metric, COUNT(*) AS value FROM cmdb.dim_ci WHERE is_current = TRUE GROUP BY ci_type ORDER BY value DESC;",
            "format": "table",
            "refId": "A"
          }
        ],
        "options": {
          "pieType": "pie",
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          },
          "tooltip": {
            "mode": "single"
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 2,
        "title": "CI Creation Rate (Last 30 Days)",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT time_bucket('1 day', created_at) AS time, COUNT(*) AS \"CIs Created\" FROM cmdb.dim_ci WHERE created_at >= NOW() - INTERVAL '30 days' GROUP BY time_bucket('1 day', created_at) ORDER BY time;",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20,
              "showPoints": "auto"
            },
            "unit": "short"
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 3,
        "title": "CI Changes Per Day (Last 30 Days)",
        "type": "barchart",
        "gridPos": {
          "x": 0,
          "y": 10,
          "w": 12,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT time_bucket('1 day', changed_at) AS time, COUNT(*) AS \"Changes\" FROM cmdb.fact_ci_changes WHERE changed_at >= NOW() - INTERVAL '30 days' GROUP BY time_bucket('1 day', changed_at) ORDER BY time;",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "options": {
          "orientation": "vertical",
          "xTickLabelRotation": -45,
          "legend": {
            "displayMode": "hidden"
          }
        }
      },
      {
        "id": 4,
        "title": "Discovery Success Rate",
        "type": "gauge",
        "gridPos": {
          "x": 12,
          "y": 10,
          "w": 6,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT ROUND(AVG(CASE WHEN status = 'completed' THEN 100.0 ELSE 0.0 END), 2) AS \"Success Rate %\" FROM connector_run_history WHERE started_at >= NOW() - INTERVAL '7 days';",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "red"
                },
                {
                  "value": 70,
                  "color": "yellow"
                },
                {
                  "value": 90,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 5,
        "title": "Total Active CIs",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 10,
          "w": 6,
          "h": 5
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS \"Active CIs\" FROM cmdb.dim_ci WHERE is_current = TRUE AND ci_status = 'active';",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "blue"
                }
              ]
            }
          }
        },
        "options": {
          "textMode": "value_and_name",
          "graphMode": "none",
          "colorMode": "background"
        }
      },
      {
        "id": 6,
        "title": "Total Relationships",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 15,
          "w": 6,
          "h": 5
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT COUNT(*) AS \"Active Relationships\" FROM cmdb.fact_ci_relationships WHERE is_active = TRUE;",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                }
              ]
            }
          }
        },
        "options": {
          "textMode": "value_and_name",
          "graphMode": "none",
          "colorMode": "background"
        }
      },
      {
        "id": 7,
        "title": "Top 10 Most Connected CIs",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 24,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT c.ci_name AS \"CI Name\", c.ci_type AS \"Type\", c.environment AS \"Environment\", (SELECT COUNT(*) FROM cmdb.fact_ci_relationships r WHERE (r.from_ci_key = c.ci_key OR r.to_ci_key = c.ci_key) AND r.is_active = TRUE) AS \"Total Connections\", (SELECT COUNT(*) FROM cmdb.fact_ci_relationships r WHERE r.from_ci_key = c.ci_key AND r.is_active = TRUE) AS \"Outgoing\", (SELECT COUNT(*) FROM cmdb.fact_ci_relationships r WHERE r.to_ci_key = c.ci_key AND r.is_active = TRUE) AS \"Incoming\" FROM cmdb.dim_ci c WHERE c.is_current = TRUE ORDER BY \"Total Connections\" DESC LIMIT 10;",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Total Connections"
              },
              "properties": [
                {
                  "id": "custom.width",
                  "value": 150
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Total Connections",
              "desc": true
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "CI Distribution by Environment",
        "type": "barchart",
        "gridPos": {
          "x": 0,
          "y": 30,
          "w": 12,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT COALESCE(environment, 'unassigned') AS metric, COUNT(*) AS value FROM cmdb.dim_ci WHERE is_current = TRUE GROUP BY COALESCE(environment, 'unassigned') ORDER BY value DESC;",
            "format": "table",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "options": {
          "orientation": "horizontal",
          "legend": {
            "displayMode": "hidden"
          }
        }
      },
      {
        "id": 9,
        "title": "CI Status Distribution",
        "type": "piechart",
        "gridPos": {
          "x": 12,
          "y": 30,
          "w": 12,
          "h": 10
        },
        "datasource": "HappyCMDB",
        "targets": [
          {
            "rawSql": "SELECT ci_status AS metric, COUNT(*) AS value FROM cmdb.dim_ci WHERE is_current = TRUE GROUP BY ci_status ORDER BY value DESC;",
            "format": "table",
            "refId": "A"
          }
        ],
        "options": {
          "pieType": "donut",
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      }
    ]
  },
  "overwrite": true
}
