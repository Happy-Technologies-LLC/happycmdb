{
  "name": "happycmdb",
  "version": "3.0.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Enterprise CMDB Platform v3.0 - Unified ITIL, TBM, and BSM with AI-powered discovery",
  "workspaces": [
    "packages/*",
    "web-ui"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:packages": "npm run build --workspace=packages/*",
    "build:web": "npm run build --workspace=web-ui",
    "dev": "npm run dev --workspaces --parallel",
    "dev:api": "npm run dev --workspace=@cmdb/api",
    "dev:web": "npm run dev --workspace=web-ui",
    "test": "npm run test --workspaces",
    "test:unit": "jest --config jest.config.unit.js",
    "test:integration": "jest --config jest.config.integration.js",
    "test:e2e": "jest --config jest.config.e2e.js",
    "test:e2e:debug": "DEBUG=true jest --config jest.config.e2e.js",
    "test:coverage": "jest --config jest.config.unit.js --coverage --coverageDirectory=coverage",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "clean:dist": "npm exec --workspaces -- rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "axios": "^1.6.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.0",
    "husky": "^8.0.0",
    "ioredis": "^5.3.0",
    "jest": "^29.0.0",
    "jest-junit": "^16.0.0",
    "neo4j-driver": "^5.15.0",
    "pg": "^8.11.0",
    "prettier": "^3.0.0",
    "prom-client": "^15.1.3",
    "testcontainers": "^12.0.3",
    "ts-jest": "^29.0.0",
    "typescript": "^5.3.0",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.899.0",
    "@opentelemetry/exporter-jaeger": "^2.1.0",
    "@opentelemetry/instrumentation": "^0.205.0",
    "@opentelemetry/instrumentation-express": "^0.54.3",
    "@opentelemetry/instrumentation-graphql": "^0.53.3",
    "@opentelemetry/instrumentation-http": "^0.205.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.37.0"
  },
  "dependencies": {
    "ldapjs": "^3.0.7"
  }
}
