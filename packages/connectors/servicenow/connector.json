{
  "type": "servicenow",
  "category": "connector",
  "connector_category": "itsm",
  "data_types": ["infrastructure", "itil"],
  "icon": "servicenow",
  "name": "ServiceNow CMDB & ITSM",
  "version": "3.0.0",
  "description": "Bi-directional integration with ServiceNow CMDB and ITSM (incidents and changes only)",
  "author": "HappyCMDB",
  "verified": true,
  "capabilities": {
    "extraction": true,
    "relationships": true,
    "incremental": true,
    "bidirectional": true
  },
  "configuration_schema": {
    "type": "object",
    "required": ["instance_url", "username", "password"],
    "properties": {
      "instance_url": {
        "type": "string",
        "description": "ServiceNow instance URL (e.g., https://dev12345.service-now.com)"
      },
      "username": {
        "type": "string",
        "description": "ServiceNow username"
      },
      "password": {
        "type": "string",
        "description": "ServiceNow password",
        "format": "password"
      },
      "sync_direction": {
        "type": "string",
        "enum": ["import", "export", "bidirectional"],
        "default": "import",
        "description": "Synchronization direction"
      }
    }
  },
  "resources": [
    {
      "id": "servers",
      "name": "Servers",
      "description": "Physical and virtual servers from cmdb_ci_server",
      "ci_type": "server",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load", "sync_to_source"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "cmdb_ci_server"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter (e.g., operational_status=1)",
            "default": ""
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 1000,
        "rate_limit": 10
      },
      "field_mappings": {
        "name": "name",
        "serial_number": "serial_number",
        "asset_tag": "asset_tag",
        "ip_address": "ip_address",
        "mac_address": "mac_address",
        "os": "os.display_value",
        "os_version": "os_version",
        "cpu_count": "cpu_count",
        "ram": "ram",
        "disk_space": "disk_space",
        "manufacturer": "manufacturer.display_value",
        "model": "model_id.display_value",
        "operational_status": "operational_status",
        "sys_created_on": "sys_created_on",
        "sys_updated_on": "sys_updated_on"
      }
    },
    {
      "id": "virtual_machines",
      "name": "Virtual Machines",
      "description": "Virtual machines from cmdb_ci_vm_instance",
      "ci_type": "virtual-machine",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "cmdb_ci_vm_instance"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter",
            "default": ""
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 1000
      },
      "field_mappings": {
        "name": "name",
        "vcpus": "vcpus",
        "memory": "memory",
        "disk_space": "disk_space",
        "host_name": "host_name.display_value",
        "vm_inst_id": "vm_inst_id",
        "guest_os": "guest_os.display_value",
        "serial_number": "serial_number",
        "ip_address": "ip_address",
        "mac_address": "mac_address"
      }
    },
    {
      "id": "databases",
      "name": "Databases",
      "description": "Database instances from cmdb_ci_db_instance",
      "ci_type": "database",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "cmdb_ci_db_instance"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter",
            "default": ""
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500
      },
      "field_mappings": {
        "name": "name",
        "db_version": "db_version",
        "db_type": "db_type.display_value",
        "instance_name": "instance_name",
        "port": "port",
        "size_bytes": "size_bytes",
        "serial_number": "serial_number",
        "ip_address": "ip_address"
      }
    },
    {
      "id": "applications",
      "name": "Applications",
      "description": "Business applications from cmdb_ci_appl",
      "ci_type": "application",
      "enabled_by_default": false,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "cmdb_ci_appl"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter",
            "default": ""
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500
      },
      "field_mappings": {
        "name": "name",
        "version": "version",
        "vendor": "vendor.display_value",
        "support_group": "support_group.display_value",
        "business_criticality": "business_criticality.display_value",
        "serial_number": "serial_number"
      }
    },
    {
      "id": "network_devices",
      "name": "Network Devices",
      "description": "Network equipment from cmdb_ci_netgear",
      "ci_type": "network-device",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "cmdb_ci_netgear"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter",
            "default": ""
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500
      },
      "field_mappings": {
        "name": "name",
        "device_type": "device_type.display_value",
        "ports": "ports",
        "firmware_version": "firmware_version",
        "location": "location.display_value",
        "serial_number": "serial_number",
        "ip_address": "ip_address",
        "mac_address": "mac_address"
      }
    },
    {
      "id": "relationships",
      "name": "CI Relationships",
      "description": "CI relationships from cmdb_rel_ci",
      "ci_type": null,
      "enabled_by_default": true,
      "operations": ["extract"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "cmdb_rel_ci"
          }
        }
      },
      "extraction": {
        "incremental": false,
        "batch_size": 10000,
        "depends_on": ["servers", "virtual_machines", "databases"]
      }
    },
    {
      "id": "incidents",
      "name": "Incidents",
      "description": "ITIL incidents from incident table",
      "type": "incident",
      "data_type": "itil",
      "target_storage": "postgresql:fact_incidents",
      "enabled_by_default": false,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "incident"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter (e.g., active=true)",
            "default": ""
          },
          "sync_closed": {
            "type": "boolean",
            "default": false,
            "description": "Sync closed/resolved incidents (high volume)"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500,
        "rate_limit": 10
      },
      "field_mappings": {
        "number": "number",
        "short_description": "short_description",
        "description": "description",
        "priority": "priority",
        "severity": "severity",
        "state": "state",
        "impact": "impact",
        "urgency": "urgency",
        "category": "category",
        "subcategory": "subcategory",
        "assigned_to": "assigned_to.display_value",
        "assignment_group": "assignment_group.display_value",
        "caller": "caller_id.display_value",
        "affected_ci": "cmdb_ci.display_value",
        "affected_ci_sys_id": "cmdb_ci.value",
        "business_service": "business_service.display_value",
        "opened_at": "opened_at",
        "resolved_at": "resolved_at",
        "closed_at": "closed_at",
        "close_code": "close_code",
        "close_notes": "close_notes",
        "resolution_code": "resolution_code",
        "sla_due": "sla_due",
        "made_sla": "made_sla",
        "caused_by": "caused_by.display_value",
        "problem": "problem_id.display_value",
        "change_request": "rfc.display_value",
        "sys_created_on": "sys_created_on",
        "sys_updated_on": "sys_updated_on"
      }
    },
    {
      "id": "changes",
      "name": "Change Requests",
      "description": "ITIL change requests from change_request table",
      "type": "change",
      "data_type": "itil",
      "target_storage": "postgresql:fact_changes",
      "enabled_by_default": false,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "table": {
            "type": "string",
            "default": "change_request"
          },
          "query": {
            "type": "string",
            "description": "ServiceNow query filter",
            "default": ""
          },
          "sync_closed": {
            "type": "boolean",
            "default": true,
            "description": "Sync closed changes for historical analysis"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500,
        "rate_limit": 10
      },
      "field_mappings": {
        "number": "number",
        "short_description": "short_description",
        "description": "description",
        "type": "type",
        "priority": "priority",
        "risk": "risk",
        "impact": "impact",
        "state": "state",
        "category": "category",
        "assignment_group": "assignment_group.display_value",
        "assigned_to": "assigned_to.display_value",
        "requested_by": "requested_by.display_value",
        "affected_cis": "cmdb_ci.display_value",
        "business_service": "business_service.display_value",
        "start_date": "start_date",
        "end_date": "end_date",
        "planned_start_date": "planned_start_date",
        "planned_end_date": "planned_end_date",
        "work_start": "work_start",
        "work_end": "work_end",
        "close_code": "close_code",
        "close_notes": "close_notes",
        "implementation_plan": "implementation_plan",
        "backout_plan": "backout_plan",
        "test_plan": "test_plan",
        "approval": "approval",
        "cab_required": "cab_required",
        "conflict_status": "conflict_status",
        "unauthorized": "unauthorized",
        "sys_created_on": "sys_created_on",
        "sys_updated_on": "sys_updated_on"
      }
    }
  ]
}
