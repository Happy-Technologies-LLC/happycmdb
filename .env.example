# =============================================================================
# HappyCMDB v3.0 - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control
#
# v3.0 Features Included:
# - ITIL v4 Service Management (always enabled)
# - TBM v5.0.1 Cost Transparency (always enabled)
# - BSM Impact Analysis (always enabled)
# - AI Discovery with Pattern Learning (enabled by default)
# - Event Streaming with Kafka (optional, disabled by default)
# - Unified Framework Integration (always enabled)
# - Multi-Stakeholder Dashboards (5 dashboards)
# - Metabase BI Integration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRATION=24h
API_KEY=your-api-key-for-service-to-service-authentication
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data-minimum-32-characters

# -----------------------------------------------------------------------------
# SSL/TLS Configuration
# -----------------------------------------------------------------------------
# Master SSL toggle (enables SSL for all services when true)
SSL_ENABLED=false

# Web UI (Nginx) SSL Configuration
NGINX_SSL_ENABLED=false
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/key.pem
NGINX_SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem
NGINX_SSL_DHPARAM_PATH=/etc/nginx/ssl/dhparam.pem

# HSTS (HTTP Strict Transport Security) Configuration
NGINX_HSTS_MAX_AGE=31536000
NGINX_HSTS_INCLUDE_SUBDOMAINS=true
NGINX_HSTS_PRELOAD=true

# -----------------------------------------------------------------------------
# Neo4j Graph Database
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=cmdb
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30000

# Neo4j SSL/TLS Configuration
NEO4J_SSL_ENABLED=false
NEO4J_BOLT_TLS_LEVEL=OPTIONAL
NEO4J_HTTPS_ENABLED=false
NEO4J_SSL_CERT_PATH=/ssl/neo4j.cert
NEO4J_SSL_KEY_PATH=/ssl/neo4j.key
NEO4J_SSL_CA_PATH=/ssl/ca.crt

# -----------------------------------------------------------------------------
# PostgreSQL (Connector Registry, Credentials, Metadata)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=cmdb
POSTGRES_USER=cmdb_user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_MAX_CONNECTIONS=20

# PostgreSQL SSL/TLS Configuration
POSTGRES_SSL_ENABLED=off
POSTGRES_SSL_MODE=prefer
POSTGRES_SSL_CERT_PATH=/ssl/server.crt
POSTGRES_SSL_KEY_PATH=/ssl/server.key
POSTGRES_SSL_CA_PATH=/ssl/ca.crt

# -----------------------------------------------------------------------------
# Redis (Cache & Job Queue)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=cmdb:

# Redis SSL/TLS Configuration
REDIS_TLS_ENABLED=false
REDIS_TLS_PORT=0
REDIS_TLS_CERT_PATH=/ssl/redis.crt
REDIS_TLS_KEY_PATH=/ssl/redis.key
REDIS_TLS_CA_PATH=/ssl/ca.crt
REDIS_TLS_AUTH_CLIENTS=no

# -----------------------------------------------------------------------------
# Kafka Event Streaming (v3.0) - Optional
# -----------------------------------------------------------------------------
# Enables real-time event streaming for CI changes, relationships, and incidents
# 11 event topics for discovery, enrichment, changes, ITIL, costs, BSM, audit, alerts, ETL, integrations, and DLQ
# Set to false for simpler deployments (uses polling instead)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=happycmdb
KAFKA_GROUP_ID=cmdb-consumers

# Kafka UI Configuration (Web interface for topic management)
KAFKA_UI_PORT=8090

# Zookeeper Configuration (managed internally by Docker Compose)
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# Topic Initialization
# Run infrastructure/scripts/init-kafka.sh after first deployment to create topics
# Topics: discovery-events, enrichment-events, change-events, itil-events, cost-events,
#         bsm-events, audit-events, alert-events, etl-events, integration-events, dlq-events

# -----------------------------------------------------------------------------
# Discovery Configuration
# -----------------------------------------------------------------------------
DISCOVERY_ENABLED=true
DISCOVERY_DEFAULT_INTERVAL=3600000
DISCOVERY_BATCH_SIZE=100
DISCOVERY_MAX_RETRIES=3
DISCOVERY_RETRY_DELAY=2000

# -----------------------------------------------------------------------------
# ETL Processing
# -----------------------------------------------------------------------------
ETL_ENABLED=true
ETL_BATCH_SIZE=1000
ETL_SYNC_INTERVAL=300000

# -----------------------------------------------------------------------------
# Graph Processing
# -----------------------------------------------------------------------------
GRAPH_RELATIONSHIP_INFERENCE_ENABLED=true
GRAPH_MAX_DEPTH=5
GRAPH_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# AI/ML Features
# -----------------------------------------------------------------------------
AI_ANOMALY_DETECTION_ENABLED=true
AI_DRIFT_DETECTION_ENABLED=true
AI_IMPACT_ANALYSIS_ENABLED=true

# -----------------------------------------------------------------------------
# v3.0 Unified Framework (ITIL + TBM + BSM)
# -----------------------------------------------------------------------------
# These features are ALWAYS ENABLED in v3.0 - no feature flags needed
# All discovered CIs are automatically enriched with:
# - ITIL v4 attributes (class, lifecycle, configuration status)
# - TBM cost allocation (resource tower, cost data)
# - BSM impact attributes (business criticality, compliance scope)
#
# The unified framework provides 10 KPIs across all stakeholder dashboards:
# - Health Score, Cost Efficiency, Risk Score, Value Score
# - Compliance Score, Availability, ROI, MTTR, MTBF, Change Success Rate

# -----------------------------------------------------------------------------
# AI Discovery & Pattern Learning (v3.0)
# -----------------------------------------------------------------------------
# Enable AI-powered discovery with LLM integration
AI_DISCOVERY_ENABLED=true

# LLM Provider Configuration
# Options: anthropic, openai, custom (for vLLM, Ollama, LocalAI, etc.)
AI_DISCOVERY_PROVIDER=anthropic
AI_DISCOVERY_MODEL=claude-sonnet-4-20250514

# Anthropic API Configuration (if using anthropic provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Configuration (if using openai provider)
OPENAI_API_KEY=your-openai-api-key-here

# Custom LLM Configuration (if using custom provider)
# For self-hosted models (vLLM, Ollama, LocalAI, Text Generation Inference)
AI_DISCOVERY_BASE_URL=http://localhost:8000/v1
AI_DISCOVERY_CUSTOM_MODEL=llama-3-70b

# LLM Parameters
AI_DISCOVERY_TEMPERATURE=0.1
AI_DISCOVERY_MAX_TOKENS=4096
AI_DISCOVERY_TIMEOUT_MS=60000

# Cost Controls
AI_DISCOVERY_MAX_COST_PER_SESSION=0.50
AI_DISCOVERY_MONTHLY_BUDGET=100.00

# Pattern Learning Configuration
AI_PATTERN_LEARNING_ENABLED=true
AI_PATTERN_MIN_SESSIONS=3              # Min similar sessions to suggest pattern
AI_PATTERN_SIMILARITY_THRESHOLD=0.7    # Tool sequence similarity threshold
AI_PATTERN_AUTO_APPROVAL_ENABLED=true
AI_PATTERN_AUTO_APPROVAL_MIN_SESSIONS=5
AI_PATTERN_AUTO_APPROVAL_MIN_CONFIDENCE=0.9

# Pattern Execution Security
AI_PATTERN_DETECTION_TIMEOUT_MS=1000   # Max time for pattern detection
AI_PATTERN_DISCOVERY_TIMEOUT_MS=10000  # Max time for pattern discovery

# Hybrid Discovery Configuration
AI_HYBRID_DISCOVERY_ENABLED=true       # Enable pattern matching + AI fallback
AI_PATTERN_CONFIDENCE_THRESHOLD=0.9    # Use pattern if confidence >= this
AI_ENABLE_LEGACY_FALLBACK=true         # Fall back to legacy workers if AI fails

# -----------------------------------------------------------------------------
# Rate Limiting (Production-Grade Configuration)
# -----------------------------------------------------------------------------
# Enable/disable rate limiting globally
RATE_LIMIT_ENABLED=true

# Internal service bypass (for service-to-service communication)
RATE_LIMIT_BYPASS_HEADER=X-Internal-Service
RATE_LIMIT_BYPASS_SECRET=your-internal-service-secret-change-this

# Tier multipliers for API keys (multiplies base rate limits)
# Standard: 5x base limit
# Premium: 10x base limit
# Enterprise: 20x base limit
RATE_LIMIT_TIER_STANDARD_MULTIPLIER=5
RATE_LIMIT_TIER_PREMIUM_MULTIPLIER=10
RATE_LIMIT_TIER_ENTERPRISE_MULTIPLIER=20

# REST API rate limits (per hour per IP for anonymous users)
RATE_LIMIT_REST_MAX=1000
RATE_LIMIT_REST_WINDOW_MS=3600000

# GraphQL rate limits (per hour per IP for anonymous users)
RATE_LIMIT_GRAPHQL_MAX=500
RATE_LIMIT_GRAPHQL_WINDOW_MS=3600000

# Health endpoint rate limits (0 = unlimited)
RATE_LIMIT_HEALTH_MAX=0
RATE_LIMIT_HEALTH_WINDOW_MS=60000

# Authentication endpoint rate limits (per hour per IP)
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=3600000

# Discovery endpoint rate limits (per hour)
RATE_LIMIT_DISCOVERY_MAX=100
RATE_LIMIT_DISCOVERY_WINDOW_MS=3600000

# Admin endpoint rate limits (per hour)
RATE_LIMIT_ADMIN_MAX=200
RATE_LIMIT_ADMIN_WINDOW_MS=3600000

# Rate limit monitoring
RATE_LIMIT_MONITORING_ENABLED=true
RATE_LIMIT_LOG_HITS=true

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
TRACING_ENABLED=false
TRACING_ENDPOINT=http://localhost:4318
AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# Grafana Dashboard Configuration
# -----------------------------------------------------------------------------
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password-change-in-production
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_DOMAIN=localhost
GRAFANA_DATABASE=grafana
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_ANONYMOUS_ROLE=Viewer

# -----------------------------------------------------------------------------
# Metabase Business Intelligence Configuration (v3.0)
# -----------------------------------------------------------------------------
METABASE_PORT=3002
METABASE_DATABASE=metabase
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=your-metabase-db-password-change-in-production
METABASE_ENCRYPTION_KEY=your-metabase-encryption-key-minimum-32-characters
METABASE_SITE_URL=http://localhost:3002

# Metabase read-only user for CMDB data mart
METABASE_READONLY_USER=metabase_readonly
METABASE_READONLY_PASSWORD=your-metabase-readonly-password-change-in-production

# Email/SMTP configuration for scheduled reports (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@happycmdb.local

# -----------------------------------------------------------------------------
# Web UI Configuration
# -----------------------------------------------------------------------------
WEB_UI_PORT=3001
WEB_UI_API_ENDPOINT=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Backup Configuration
# -----------------------------------------------------------------------------
# Backup directory (host path for storing backups)
BACKUP_DIR=/var/backups/happycmdb

# Backup log directory
BACKUP_LOG_DIR=/var/log/happycmdb/backups

# Retention policy (number of backups to keep)
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12

# Cloud storage upload (S3 or Azure Blob)
BACKUP_UPLOAD_ENABLED=false
BACKUP_STORAGE_TYPE=s3

# AWS S3 Configuration (if using S3 for backup uploads)
BACKUP_S3_BUCKET=my-backup-bucket
BACKUP_S3_PREFIX=happycmdb
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Azure Blob Storage Configuration (if using Azure for backup uploads)
BACKUP_AZURE_CONTAINER=happycmdb-backups
BACKUP_AZURE_PREFIX=happycmdb
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_ACCESS_KEY=your-storage-access-key

# Backup notifications (webhook URL for Slack, Teams, or custom endpoint)
BACKUP_NOTIFICATION_ENABLED=false
BACKUP_NOTIFICATION_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Backup health check thresholds
BACKUP_MAX_AGE_HOURS=25
BACKUP_MIN_COUNT=3
DISK_USAGE_THRESHOLD=85

# -----------------------------------------------------------------------------
# Seed Data Configuration (Development/Testing Only)
# -----------------------------------------------------------------------------
# SECURITY: These are ONLY for running the seed-data script in dev/test.
# Generate password hash: node -e "console.log(require('bcryptjs').hashSync('YourPassword', 10))"
SEED_USER_EMAIL=admin@happycmdb.local
SEED_USER_USERNAME=admin
SEED_USER_PASSWORD=your-admin-password-change-this
SEED_USER_PASSWORD_HASH=your-bcrypt-hash-generated-from-password-above

# =============================================================================
# v3.0 CONNECTOR CREDENTIALS
# =============================================================================
# NOTE: Connector credentials are stored in PostgreSQL using the unified
# credential system with encryption. DO NOT add credentials here as env vars.
#
# To configure connectors:
# 1. Create credential records via Web UI or API
# 2. Associate credentials with discovery definitions
# 3. Credentials support multiple auth methods per provider
#
# See documentation: http://localhost:8080/components/credentials
# =============================================================================

# =============================================================================
# REMOVED IN v2.0+ (Legacy from v1.0)
# =============================================================================
# The following env vars are NO LONGER USED:
# - AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY (use credential system)
# - AZURE_CLIENT_ID, AZURE_CLIENT_SECRET (use credential system)
# - GCP_PROJECT_ID, GCP_SERVICE_ACCOUNT_KEY_PATH (use credential system)
# - SERVICENOW_USERNAME, SERVICENOW_PASSWORD (use credential system)
# - FEATURE_AWS_INGESTION, FEATURE_AZURE_INGESTION (removed)
# - AWS_ENABLED, AZURE_ENABLED, GCP_ENABLED (removed)
#
# All connector authentication now uses the unified credential system
# stored securely in PostgreSQL with encryption.
# =============================================================================
