{
  "id": "bmc-remedy",
  "type": "bmc-remedy",
  "category": "connector",
  "connector_category": "itsm",
  "data_types": ["infrastructure", "itil"],
  "name": "BMC Remedy ITSM",
  "version": "1.0.0",
  "description": "Integration with BMC Remedy IT Service Management for CMDB, incidents, and changes",
  "author": "HappyCMDB",
  "verified": true,
  "icon": "bmc",
  "provider": "bmc",
  "protocol": "basic_auth",
  "logo_url": "https://www.bmc.com/content/dam/bmc/corporate/bmc-logo.svg",
  "documentation_url": "https://docs.bmc.com/docs/ars2002/",
  "capabilities": {
    "extraction": true,
    "relationships": true,
    "incremental": true,
    "bidirectional": false
  },
  "configuration_schema": {
    "type": "object",
    "required": ["server_url", "username", "password"],
    "properties": {
      "server_url": {
        "type": "string",
        "description": "BMC Remedy server URL (e.g., https://remedy.company.com:8443)"
      },
      "username": {
        "type": "string",
        "description": "AR System username"
      },
      "password": {
        "type": "string",
        "description": "AR System password",
        "format": "password"
      },
      "api_version": {
        "type": "string",
        "enum": ["v1", "v2"],
        "default": "v1",
        "description": "REST API version"
      }
    }
  },
  "resources": [
    {
      "id": "computers",
      "name": "Computers",
      "description": "Computer systems from BMC.ASSET form",
      "type": "server",
      "data_type": "infrastructure",
      "ci_type": "server",
      "target_storage": "neo4j",
      "enabled_by_default": true,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "form_name": {
            "type": "string",
            "default": "BMC.ASSET"
          },
          "qualification": {
            "type": "string",
            "description": "AR System qualification (filter)",
            "default": "'DatasetId' = \"BMC.ASSET\" AND 'ClassId' = \"BMC_ComputerSystem\""
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500,
        "rate_limit": 10
      },
      "field_mappings": {
        "name": "Name",
        "asset_tag": "AssetTag",
        "serial_number": "SerialNumber",
        "manufacturer": "Manufacturer",
        "model": "Model",
        "status": "Status",
        "operational_status": "OperationalStatus",
        "location": "Site",
        "owner": "Owner",
        "department": "Department",
        "cost_center": "CostCenter",
        "ip_address": "IPAddress",
        "mac_address": "MACAddress",
        "os": "OSName",
        "os_version": "OSVersion",
        "cpu": "CPUType",
        "ram_mb": "Memory",
        "disk_gb": "DiskSpace",
        "created": "CreateDate",
        "updated": "ModifiedDate"
      }
    },
    {
      "id": "incidents",
      "name": "Incidents",
      "description": "IT incidents from HPD:IncidentInterface form",
      "type": "incident",
      "data_type": "itil",
      "target_storage": "postgresql:fact_incidents",
      "enabled_by_default": false,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "form_name": {
            "type": "string",
            "default": "HPD:IncidentInterface"
          },
          "qualification": {
            "type": "string",
            "description": "AR System qualification filter",
            "default": "'Status' < 5"
          },
          "sync_closed": {
            "type": "boolean",
            "default": false,
            "description": "Sync closed/resolved incidents"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500,
        "rate_limit": 10
      },
      "field_mappings": {
        "number": "Incident Number",
        "short_description": "Description",
        "description": "Detailed Decription",
        "priority": "Priority",
        "severity": "Severity",
        "state": "Status",
        "impact": "Impact",
        "urgency": "Urgency",
        "category": "Categorization Tier 1",
        "subcategory": "Categorization Tier 2",
        "assigned_to": "Assignee",
        "assignment_group": "Assigned Group",
        "caller": "First Name",
        "affected_ci": "CI Name",
        "affected_ci_id": "CI FormName",
        "business_service": "Service",
        "opened_at": "Submit Date",
        "resolved_at": "Resolved Date",
        "closed_at": "Closed Date",
        "close_code": "Resolution",
        "resolution": "Resolution",
        "sla_due": "SLA Due Date",
        "created": "Submit Date",
        "updated": "Last Modified Date"
      }
    },
    {
      "id": "changes",
      "name": "Change Requests",
      "description": "Change requests from CHG:ChangeInterface form",
      "type": "change",
      "data_type": "itil",
      "target_storage": "postgresql:fact_changes",
      "enabled_by_default": false,
      "operations": ["extract", "transform", "load"],
      "configuration_schema": {
        "properties": {
          "form_name": {
            "type": "string",
            "default": "CHG:ChangeInterface"
          },
          "qualification": {
            "type": "string",
            "description": "AR System qualification filter",
            "default": ""
          },
          "sync_closed": {
            "type": "boolean",
            "default": true,
            "description": "Sync closed changes for historical analysis"
          }
        }
      },
      "extraction": {
        "incremental": true,
        "batch_size": 500,
        "rate_limit": 10
      },
      "field_mappings": {
        "number": "Change Number",
        "short_description": "Summary",
        "description": "Detailed Description",
        "type": "Change Type",
        "priority": "Priority",
        "risk": "Risk Level",
        "impact": "Impact",
        "state": "Status",
        "category": "Category",
        "assignment_group": "Change Manager",
        "assigned_to": "Assigned To",
        "requested_by": "Requester",
        "affected_cis": "CI Name",
        "business_service": "Business Service",
        "start_date": "Scheduled Start Date",
        "end_date": "Scheduled End Date",
        "planned_start_date": "Planned Start",
        "planned_end_date": "Planned End",
        "work_start": "Actual Start",
        "work_end": "Actual End",
        "implementation_plan": "Implementation Plan",
        "backout_plan": "Backout Plan",
        "test_plan": "Test Plan",
        "approval": "Approval Status",
        "cab_required": "CAB Required",
        "created": "Submit Date",
        "updated": "Last Modified Date"
      }
    }
  ],
  "authentication": {
    "required": true,
    "methods": ["basic_auth"],
    "fields": [
      {
        "name": "username",
        "label": "Username",
        "type": "string",
        "required": true,
        "sensitive": false
      },
      {
        "name": "password",
        "label": "Password",
        "type": "string",
        "required": true,
        "sensitive": true
      }
    ]
  },
  "rate_limits": {
    "requests_per_second": 5,
    "requests_per_minute": 200,
    "requests_per_hour": 5000
  },
  "supported_operations": [
    "discover_computers",
    "sync_incidents",
    "sync_changes"
  ],
  "default_schedule": "0 */6 * * *",
  "tags": [
    "itsm",
    "bmc",
    "remedy",
    "cmdb",
    "incident-management",
    "change-management",
    "problem-management",
    "asset-management"
  ]
}
