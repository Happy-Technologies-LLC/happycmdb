{
  "type": "dell-emc",
  "id": "dell-emc-storage",
  "name": "Dell EMC Storage",
  "version": "1.0.0",
  "description": "Dell EMC Storage connector for Unity, PowerStore, and PowerMax storage arrays. Discovers storage arrays, pools, volumes, and connected hosts.",
  "author": "HappyCMDB",
  "category": "connector",
  "connector_category": "storage",
  "icon": "dell-emc",
  "protocol": "rest",
  "tags": [
    "dell",
    "emc",
    "storage",
    "unity",
    "powerstore",
    "powermax",
    "san",
    "enterprise"
  ],
  "capabilities": {
    "extraction": true,
    "relationships": true,
    "incremental": true,
    "bidirectional": false
  },
  "authentication": {
    "type": "basic",
    "fields": [
      {
        "name": "username",
        "type": "string",
        "required": true,
        "description": "Dell EMC storage array username"
      },
      {
        "name": "password",
        "type": "password",
        "required": true,
        "description": "Dell EMC storage array password"
      }
    ]
  },
  "configuration": {
    "schema": {
      "type": "object",
      "required": [
        "management_url",
        "username",
        "password",
        "array_type"
      ],
      "properties": {
        "management_url": {
          "type": "string",
          "title": "Management URL",
          "description": "Dell EMC storage array management URL (e.g., https://array.company.com)",
          "format": "uri",
          "examples": [
            "https://unity.company.com",
            "https://powerstore.company.com"
          ]
        },
        "username": {
          "type": "string",
          "title": "Username",
          "description": "Dell EMC storage array username with read access",
          "minLength": 1
        },
        "password": {
          "type": "string",
          "title": "Password",
          "description": "Dell EMC storage array password",
          "format": "password",
          "minLength": 1
        },
        "array_type": {
          "type": "string",
          "title": "Array Type",
          "description": "Dell EMC storage array type",
          "enum": [
            "unity",
            "powerstore",
            "powermax"
          ],
          "default": "unity"
        },
        "verify_ssl": {
          "type": "boolean",
          "title": "Verify SSL Certificate",
          "description": "Verify SSL certificate when connecting to storage array",
          "default": true
        },
        "discovery_interval": {
          "type": "integer",
          "title": "Discovery Interval (minutes)",
          "description": "How often to discover storage resources (in minutes)",
          "minimum": 5,
          "maximum": 1440,
          "default": 60
        },
        "timeout": {
          "type": "integer",
          "title": "Request Timeout (seconds)",
          "description": "HTTP request timeout in seconds",
          "minimum": 10,
          "maximum": 300,
          "default": 30
        }
      }
    },
    "ui_schema": {
      "management_url": {
        "ui:placeholder": "https://array.company.com"
      },
      "username": {
        "ui:placeholder": "admin"
      },
      "password": {
        "ui:widget": "password"
      },
      "array_type": {
        "ui:widget": "select"
      },
      "verify_ssl": {
        "ui:widget": "checkbox"
      }
    }
  },
